# ==============================================================================
# BOTWATEL - ENVIRONMENT CONFIGURATION TEMPLATE
# Salin file ini dan ubah namanya menjadi '.env', lalu isi nilainya dengan benar.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. TELEGRAM API CREDENTIALS
# Dapatkan API_ID dan API_HASH akun Anda melalui situs resmi: https://my.telegram.org
# ------------------------------------------------------------------------------
API_ID=
API_HASH=

# ------------------------------------------------------------------------------
# 2. TELEGRAM TARGET CHATS FILTER
# Masukkan ID Chat target (DM, Group, atau Channel) yang ingin dipantau.
# Gunakan tanda koma (,) jika ingin memantau lebih dari satu chat sekaligus.
# Contoh: 123456789,-100123456789 (Gunakan minus jika ID grup/channel diawali minus)
# Kosongkan jika ingin meloloskan semua jenis DM/Private Chat yang masuk.
# ------------------------------------------------------------------------------
TELEGRAM_TARGET_CHATS=

# ------------------------------------------------------------------------------
# 3. WHATSAPP REST API & DESTINATION Target
# WA_API_URL                       : URL server Node.js Baileys Anda.
# WA_TARGET_NUMBER                 : Nomor target pengiriman chat pribadi (DM).
# WA_COMMUNITY_ANNOUNCEMENT_NUMBER : ID khusus untuk grup pengumuman komunitas.
# 
# *Catatan: Gunakan kode negara tanpa tanda plus (+), contoh: 628123456789
# ------------------------------------------------------------------------------
WA_API_URL=http://localhost:3000
WA_TARGET_NUMBER=
WA_COMMUNITY_ANNOUNCEMENT_NUMBER=

# ------------------------------------------------------------------------------
# 4. DATABASE & SYSTEM ENVIRONMENT LOGGING
# DATABASE_PATH : Lokasi absolut/relatif penyimpanan file SQLite database.
# LOG_LEVEL     : Tingkat rincian log di terminal (DEBUG, INFO, WARNING, ERROR).
# ------------------------------------------------------------------------------
DATABASE_PATH=database/botwatel.db
LOG_LEVEL=INFO